# ── Azure OpenAI ──────────────────────────────────────
AZURE_OPENAI_API_KEY=your_openai_key
AZURE_OPENAI_ENDPOINT=https://your-openai-resource-endpoint.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-07-18

# ── Azure Speech ──────────────────────────────────────
AZURE_SPEECH_KEY=your_speech_key
AZURE_SPEECH_REGION=eastus

# ── Azure Computer Vision ─────────────────────────────
AZURE_VISION_KEY=your_computer_vision_key
AZURE_VISION_ENDPOINT=https://your-computer-vision-resource-endpoint.cognitiveservices.azure.com/

# ── Azure Language ────────────────────────────────────
AZURE_LANGUAGE_KEY=your_language_service_key
AZURE_LANGUAGE_ENDPOINT=https://your-language-service-resource-endpoint.cognitiveservices.azure.com/

WEBCHAT_SECRET=your_webchat_secret

AZURE_CLIENT_ID=your_client_id
AZURE_TENANT_ID=your_tenant_id
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_CLIENT_SECRET=your_client_secret
# ── App settings ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true